{
  "name": "neuralops-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "build:web": "npm run build --workspace=web",
    "start:web": "npm run start --workspace=web",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "turbo": "latest"
  }
}